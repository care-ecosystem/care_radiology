		{
			"name": "02. DCM4CHEE - QIDO-RS (Query)",
			"item": [
				{
					"name": "Search All Studies",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/dicom+json",
								"type": "text"
							}
						],
						"url": {
							"raw": "http://localhost:8080/dcm4chee-arc/aets/DCM4CHEE/rs/studies",
							"protocol": "http",
							"host": ["localhost"],
							"port": "8080",
							"path": ["dcm4chee-arc", "aets", "DCM4CHEE", "rs", "studies"]
						},
						"description": "Query all studies in PACS using QIDO-RS"
					},
					"response": []
				},
				{
					"name": "Search Studies by Patient Name",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/dicom+json",
								"type": "text"
							}
						],
						"url": {
							"raw": "http://localhost:8080/dcm4chee-arc/aets/DCM4CHEE/rs/studies?PatientName=*DOE*",
							"protocol": "http",
							"host": ["localhost"],
							"port": "8080",
							"path": ["dcm4chee-arc", "aets", "DCM4CHEE", "rs", "studies"],
							"query": [
								{
									"key": "PatientName",
									"value": "*DOE*",
									"description": "Wildcard search for patient name"
								}
							]
						},
						"description": "Search studies by patient name using wildcard"
					},
					"response": []
				},
				{
					"name": "Search Studies by Date Range",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/dicom+json",
								"type": "text"
							}
						],
						"url": {
							"raw": "http://localhost:8080/dcm4chee-arc/aets/DCM4CHEE/rs/studies?StudyDate=20260101-20261231&limit=10",
							"protocol": "http",
							"host": ["localhost"],
							"port": "8080",
							"path": ["dcm4chee-arc", "aets", "DCM4CHEE", "rs", "studies"],
							"query": [
								{
									"key": "StudyDate",
									"value": "20260101-20261231",
									"description": "Date range: YYYYMMDD-YYYYMMDD"
								},
								{
									"key": "limit",
									"value": "10",
									"description": "Limit results"
								}
							]
						},
						"description": "Search studies within a date range"
					},
					"response": []
				},
				{
					"name": "Search Series for Study",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/dicom+json",
								"type": "text"
							}
						],
						"url": {
							"raw": "http://localhost:8080/dcm4chee-arc/aets/DCM4CHEE/rs/studies/{{StudyInstanceUID}}/series",
							"protocol": "http",
							"host": ["localhost"],
							"port": "8080",
							"path": ["dcm4chee-arc", "aets", "DCM4CHEE", "rs", "studies", "{{StudyInstanceUID}}", "series"]
						},
						"description": "Query all series for a specific study\n\nReplace {{StudyInstanceUID}} with actual Study Instance UID"
					},
					"response": []
				},
				{
					"name": "Search Instances in Series",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/dicom+json",
								"type": "text"
							}
						],
						"url": {
							"raw": "http://localhost:8080/dcm4chee-arc/aets/DCM4CHEE/rs/studies/{{StudyInstanceUID}}/series/{{SeriesInstanceUID}}/instances",
							"protocol": "http",
							"host": ["localhost"],
							"port": "8080",
							"path": ["dcm4chee-arc", "aets", "DCM4CHEE", "rs", "studies", "{{StudyInstanceUID}}", "series", "{{SeriesInstanceUID}}", "instances"]
						},
						"description": "Query instances within a specific series"
					},
					"response": []
				}
			]
		},
		{
			"name": "03. DCM4CHEE - WADO-RS (Retrieve)",
			"item": [
				{
					"name": "Retrieve Study Metadata",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/dicom+json",
								"type": "text"
							}
						],
						"url": {
							"raw": "http://localhost:8080/dcm4chee-arc/aets/DCM4CHEE/rs/studies/{{StudyInstanceUID}}/metadata",
							"protocol": "http",
							"host": ["localhost"],
							"port": "8080",
							"path": ["dcm4chee-arc", "aets", "DCM4CHEE", "rs", "studies", "{{StudyInstanceUID}}", "metadata"]
						},
						"description": "Retrieve all metadata for a study"
					},
					"response": []
				},
				{
					"name": "Retrieve Instance",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "multipart/related; type=application/dicom",
								"type": "text"
							}
						],
						"url": {
							"raw": "http://localhost:8080/dcm4chee-arc/aets/DCM4CHEE/rs/studies/{{StudyInstanceUID}}/series/{{SeriesInstanceUID}}/instances/{{SOPInstanceUID}}",
							"protocol": "http",
							"host": ["localhost"],
							"port": "8080",
							"path": ["dcm4chee-arc", "aets", "DCM4CHEE", "rs", "studies", "{{StudyInstanceUID}}", "series", "{{SeriesInstanceUID}}", "instances", "{{SOPInstanceUID}}"]
						},
						"description": "Retrieve a DICOM instance"
					},
					"response": []
				},
				{
					"name": "Retrieve Rendered Thumbnail",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "image/jpeg",
								"type": "text"
							}
						],
						"url": {
							"raw": "http://localhost:8080/dcm4chee-arc/aets/DCM4CHEE/rs/studies/{{StudyInstanceUID}}/series/{{SeriesInstanceUID}}/instances/{{SOPInstanceUID}}/rendered?viewport=100,100",
							"protocol": "http",
							"host": ["localhost"],
							"port": "8080",
							"path": ["dcm4chee-arc", "aets", "DCM4CHEE", "rs", "studies", "{{StudyInstanceUID}}", "series", "{{SeriesInstanceUID}}", "instances", "{{SOPInstanceUID}}", "rendered"],
							"query": [
								{
									"key": "viewport",
									"value": "100,100",
									"description": "Thumbnail size"
								}
							]
						},
						"description": "Retrieve rendered JPEG thumbnail of DICOM instance"
					},
					"response": []
				}
			]
		},
		{
