	"item": [
		{
			"name": "01. Health Checks",
			"item": [
				{
					"name": "DCM4CHEE - Health Check",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "http://localhost:8080/dcm4chee-arc/ui2",
							"protocol": "http",
							"host": ["localhost"],
							"port": "8080",
							"path": ["dcm4chee-arc", "ui2"]
						},
						"description": "Check if DCM4CHEE UI is accessible\n\nPort-forward command:\nkubectl --kubeconfig=/Users/jagankumar/Office/Work/repo/Care/care_deployment/k3s/kubeconfig port-forward -n care svc/radiology-dcm4chee 8080:8080"
					},
					"response": []
				},
				{
