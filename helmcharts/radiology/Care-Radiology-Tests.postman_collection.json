								},
								{
									"key": "password",
									"value": "admin",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "http://localhost:9990/dcm4chee-arc/storage",
							"protocol": "http",
							"host": ["localhost"],
							"port": "9990",
							"path": ["dcm4chee-arc", "storage"]
						},
						"description": "List storage systems (MinIO configuration)"
					},
					"response": []
				},
				{
					"name": "Get Queue Status",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "http://localhost:8080/dcm4chee-arc/monitor/queues",
							"protocol": "http",
							"host": ["localhost"],
							"port": "8080",
							"path": ["dcm4chee-arc", "monitor", "queues"]
						},
						"description": "Monitor internal processing queues"
					},
					"response": []
				}
			]
		},
		{
			"name": "05. LDAP Tests",
			"item": [
				{
					"name": "LDAP Connection Test",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "http://localhost:8080/dcm4chee-arc/ui2",
							"protocol": "http",
							"host": ["localhost"],
							"port": "8080",
							"path": ["dcm4chee-arc", "ui2"]
						},
						"description": "DCM4CHEE uses LDAP for authentication. Test by accessing the UI and checking if LDAP auth works.\n\nDefault LDAP credentials:\nDN: cn=admin,dc=dcm4che,dc=org\nPassword: admin\n\nNote: Direct LDAP testing requires ldapsearch or similar tools. This tests LDAP integration via DCM4CHEE."
					},
					"response": []
				},
				{
					"name": "Test LDAP Port (TCP Check)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "http://localhost:389/",
							"protocol": "http",
							"host": ["localhost"],
							"port": "389",
							"path": [""]
						},
						"description": "This will fail with HTTP, but confirms port is open\n\nPort-forward command:\nkubectl --kubeconfig=/Users/jagankumar/Office/Work/repo/Care/care_deployment/k3s/kubeconfig port-forward -n care svc/radiology-ldap 389:389\n\nUse ldapsearch for actual LDAP testing:\nldapsearch -x -H ldap://localhost:389 -D \"cn=admin,dc=dcm4che,dc=org\" -w admin -b \"dc=dcm4che,dc=org\""
					},
					"response": []
				}
			]
		},
